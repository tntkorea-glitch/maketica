generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 사용자 ───────────────────────────────────────────────

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  name        String?
  phone       String?
  role        UserRole   @default(PUBLISHER)
  status      UserStatus @default(ACTIVE)
  image       String?

  // 인증
  passwordHash String?

  // 마케터 정보
  bankName    String?
  bankAccount String?
  bankHolder  String?
  grade       PublisherGrade @default(BRONZE)

  // 광고주 프로필 (1:1)
  advertiserProfile AdvertiserProfile?

  // 광고주로서
  campaigns   Campaign[]

  // 마케터로서
  applications    Application[]
  earnings        Earning[]
  withdraws       WithdrawRequest[]

  // NextAuth
  accounts    Account[]
  sessions    Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  ADVERTISER
  PUBLISHER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum PublisherGrade {
  BRONZE    // 기본 (60% 지급)
  SILVER    // 월 50건 이상 (65%)
  GOLD      // 월 200건 이상 (70%)
  PLATINUM  // 월 500건 이상 (75%)
}

// ─── 광고주 프로필 + 예치금 ────────────────────────────────

model AdvertiserProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  businessNo  String?  // 사업자등록번호
  balance     Int      @default(0)  // 예치금 잔액 (원)

  charges     Charge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 캠페인 ───────────────────────────────────────────────

model Campaign {
  id           String           @id @default(cuid())
  advertiserId String
  advertiser   User             @relation(fields: [advertiserId], references: [id])

  title        String
  description  String           @db.Text
  category     CampaignCategory
  type         CampaignType     @default(CPA)
  status       CampaignStatus   @default(PENDING)

  // 단가 (원) — 스프레드가 플랫폼 수익
  advertiserPrice Int           // 광고주 지불 단가
  publisherPrice  Int           // 마케터 지급 단가

  // 예산/기간
  budget       Int              // 총 예산 (원)
  usedBudget   Int     @default(0)
  startDate    DateTime?
  endDate      DateTime?

  // 랜딩/목표
  landingUrl   String
  targetAction String           // "상담신청", "회원가입", "구매" 등
  requirement  String?  @db.Text // 참여 조건 안내

  // 등급 제한 (고단가 캠페인은 SILVER 이상만)
  minGrade     PublisherGrade   @default(BRONZE)

  // 승인율 표시 (마케터에게 공개, 0~100)
  approvalRate Int?

  // 이미지
  imageUrl     String?

  applications Application[]
  conversions  Conversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CampaignType {
  CPA  // Cost Per Action
  CPS  // Cost Per Sale
  CPL  // Cost Per Lead
  CPC  // Cost Per Click
  CPM  // Cost Per Mille
}

enum CampaignCategory {
  LOAN         // 대출 (3~10만원)
  INSURANCE    // 보험 (3~8만원)
  LEGAL        // 개인회생/법률 (5~15만원)
  PLASTIC      // 성형/다이어트 (2~6만원)
  BEAUTY       // 뷰티/피부/반영구
  EDUCATION    // 교육/자격증
  HEALTHCARE   // 건강/의료
  REALESTATE   // 부동산
  IT           // IT/앱/게임
  FOOD         // 식품/다이어트
  SHOPPING     // 쇼핑/이커머스
  OTHER        // 기타
}

enum CampaignStatus {
  PENDING   // 검토중 (관리자 승인 대기)
  ACTIVE    // 진행중
  PAUSED    // 일시중지
  ENDED     // 종료
  REJECTED  // 반려
}

// ─── 마케터 캠페인 신청 + 트래킹 링크 ─────────────────────

model Application {
  id          String            @id @default(cuid())
  campaignId  String
  campaign    Campaign          @relation(fields: [campaignId], references: [id])
  publisherId String
  publisher   User              @relation(fields: [publisherId], references: [id])

  status      ApplicationStatus @default(PENDING)

  // 트래킹 링크
  trackingCode String           @unique @default(cuid())

  // 통계
  clickCount      Int @default(0)
  conversionCount Int @default(0)

  conversions Conversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, publisherId])
}

enum ApplicationStatus {
  PENDING   // 신청중
  APPROVED  // 승인됨
  REJECTED  // 반려됨
}

// ─── 전환 기록 (DB/리드) ──────────────────────────────────

model Conversion {
  id            String           @id @default(cuid())
  campaignId    String
  campaign      Campaign         @relation(fields: [campaignId], references: [id])
  applicationId String
  application   Application      @relation(fields: [applicationId], references: [id])

  status        ConversionStatus @default(PENDING)

  // 단가 스냅샷 (전환 시점 기준으로 고정)
  advertiserPrice Int
  publisherPrice  Int

  // 잠재고객 정보 (DB)
  leadName  String?
  leadPhone String?
  leadEmail String?

  // 트래픽 정보
  ipAddress     String?
  userAgent     String?
  referer       String?
  trafficSource TrafficSource?  // 블로그/SNS/카페 등

  // 검증
  approvedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?

  // 정산 연결
  earningId String?
  earning   Earning? @relation(fields: [earningId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ConversionStatus {
  PENDING   // 확정 대기
  APPROVED  // 승인 확정
  REJECTED  // 반려
  PAID      // 정산 완료
}

enum TrafficSource {
  BLOG      // 네이버 블로그
  CAFE      // 네이버 카페
  SNS       // 인스타/틱톡/페북
  YOUTUBE   // 유튜브
  COMMUNITY // 당근/커뮤니티
  DIRECT    // 직접 입력
  OTHER     // 기타
}

// ─── 마케터 수익 (주급 정산 단위) ────────────────────────

model Earning {
  id          String        @id @default(cuid())
  publisherId String
  publisher   User          @relation(fields: [publisherId], references: [id])

  amount      Int           // 수익금 (원)
  status      EarningStatus @default(PENDING)

  conversions Conversion[]

  // 주급 정산 식별 (예: "2026-W18")
  settleWeek  String?
  settledAt   DateTime?

  createdAt DateTime @default(now())
}

enum EarningStatus {
  PENDING   // 대기
  CONFIRMED // 확정
  PAID      // 지급완료
}

// ─── 출금 신청 ────────────────────────────────────────────

model WithdrawRequest {
  id          String         @id @default(cuid())
  publisherId String
  publisher   User           @relation(fields: [publisherId], references: [id])

  amount      Int            // 출금 신청액 (원)
  status      WithdrawStatus @default(PENDING)

  bankName    String
  bankAccount String
  bankHolder  String

  processedAt DateTime?
  adminNote   String?

  createdAt DateTime @default(now())
}

enum WithdrawStatus {
  PENDING    // 신청중
  PROCESSING // 처리중
  COMPLETED  // 완료
  REJECTED   // 반려
}

// ─── 광고주 예치금 충전 ────────────────────────────────────

model Charge {
  id                  String      @id @default(cuid())
  advertiserProfileId String
  advertiserProfile   AdvertiserProfile @relation(fields: [advertiserProfileId], references: [id])

  amount    Int          // 충전액 (원)
  status    ChargeStatus @default(PENDING)
  method    String       // "card", "transfer"

  txId        String?    // 결제 트랜잭션 ID
  confirmedAt DateTime?

  createdAt DateTime @default(now())
}

enum ChargeStatus {
  PENDING   // 입금 대기
  CONFIRMED // 입금 확인
  FAILED    // 실패
}

// ─── NextAuth ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
